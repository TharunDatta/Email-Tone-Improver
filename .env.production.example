# 🔒 PRODUCTION ENVIRONMENT VARIABLES
# This file shows what needs to be set in Vercel for production deployment
# DO NOT commit actual secrets - use Vercel's Environment Variables UI

# GEMINI API CONFIGURATION
# Get from: https://aistudio.google.com/app/apikey
# RESTRICTION: Must restrict to generativelanguage.googleapis.com API only
GEMINI_API_KEY=your_gemini_api_key_restricted_to_api_only

# SUPABASE CONFIGURATION  
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_with_rls_enabled
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_server_only

# JWT CONFIGURATION
# CRITICAL: Must be 32+ random characters, unique per deployment
# Generate with: [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Maximum 256}))
JWT_SECRET=your-32-plus-character-random-string-unique-per-deployment

# ADMIN CREDENTIALS
# Email for admin access (no sensitive data in this field)
ADMIN_EMAIL=admin@etherealtone.ai

# Admin password HASH (not plain password!)
# CRITICAL: Must use bcrypt hash, NOT plain text password
# Generate with: node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('YOUR_PASSWORD', 10))"
# Result will look like: $2a$10$...
ADMIN_PASSWORD_HASH=$2a$10$your_bcrypt_generated_hash_here

# FRONTEND URL
# Use your actual Vercel deployment domain
FRONTEND_URL=https://your-domain.vercel.app

# NODE ENVIRONMENT
# MUST be 'production' for Vercel deployment
NODE_ENV=production
